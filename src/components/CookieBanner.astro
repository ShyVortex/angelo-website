---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cookiesUrl: string =
  lang === "it"
    ? "https://www.iubenda.com/privacy-policy/42688437/cookie-policy"
    : "https://www.iubenda.com/privacy-policy/59623685/cookie-policy";
---

<!-- Consent Banner container -->
<div
  id="consent-banner"
  class="fixed bottom-6 left-6 right-6 md:left-auto md:right-6 md:w-[450px] z-50 bg-bg-card border border-route/20 rounded-2xl shadow-xl p-6 transition-all duration-500 transform translate-y-30 opacity-0 pointer-events-none flex flex-col gap-4 text-main text-sm"
>
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-base font-semibold flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5 text-btn-highlight"
      >
        <path
          d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10c0-.182-.019-.36-.027-.54a5.999 5.999 0 0 1-5.433-5.433A10.025 10.025 0 0 0 12 2Zm2.5 13a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm-5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm2.5-5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"
        ></path>
      </svg>
      {t("cookie.banner.title")}
    </h3>
  </div>

  <p class="text-route text-[13px] leading-relaxed">
    {t("cookie.banner.description")}{" "}
    <a
      href={cookiesUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-1 text-highlight hover:underline font-medium flex items-center gap-0.5"
    >
      {t("cookie.banner.policy_link")}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="w-3 h-3 inline"
      >
        <path
          d="M12.232 4.232a2.5 2.5 0 0 1 3.536 3.536l-1.225 1.224a.75.75 0 0 0 1.061 1.06l1.224-1.224a4 4 0 0 0-5.656-5.656l-3 3a4 4 0 0 0 .225 5.865.75.75 0 0 0 .977-1.138 2.5 2.5 0 0 1-.142-3.667l3-3Z"
        ></path>
        <path
          d="M11.603 7.963a.75.75 0 0 0-.977 1.138 2.5 2.5 0 0 1 .142 3.667l-3 3a2.5 2.5 0 0 1-3.536-3.536l1.225-1.224a.75.75 0 0 0-1.061-1.06l-1.224 1.224a4 4 0 1 0 5.656 5.656l3-3a4 4 0 0 0-.225-5.865Z"
        ></path>
      </svg>
    </a>
  </p>

  <!-- Preferences panel (hidden by default) -->
  <div
    id="consent-preferences-panel"
    class="hidden flex flex-col gap-3 pt-2 border-t border-route/10"
  >
    <div class="flex flex-col gap-1">
      <label
        class="flex items-center justify-between font-medium cursor-not-allowed"
      >
        <span class="flex flex-col">
          <span>{t("cookie.banner.technical")}</span>
          <span class="text-[11px] text-route font-normal"
            >{t("cookie.banner.technical_desc")}</span
          >
        </span>
        <input
          type="checkbox"
          checked
          disabled
          class="w-4 h-4 rounded text-btn-highlight accent-btn-highlight cursor-not-allowed"
        />
      </label>
    </div>

    <div class="flex flex-col gap-1">
      <label
        class="flex items-center justify-between font-medium cursor-pointer"
      >
        <span class="flex flex-col pr-4">
          <span>{t("cookie.banner.analytics")}</span>
          <span class="text-[11px] text-route font-normal"
            >{t("cookie.banner.analytics_desc")}</span
          >
        </span>
        <input
          type="checkbox"
          id="consent-pref-analytics"
          class="w-4 h-4 rounded text-btn-highlight accent-btn-highlight cursor-pointer"
        />
      </label>
    </div>
  </div>

  <!-- Action buttons: Accept and Decline are in equal visual prominence -->
  <div class="flex flex-col gap-2 mt-2">
    <div id="consent-banner-primary-actions" class="grid grid-cols-2 gap-3">
      <button
        id="consent-btn-decline"
        class="w-full py-2.5 px-4 rounded-xl font-medium text-white bg-btn-highlight hover:bg-btn-highlight/90 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer text-center text-[14px]"
      >
        {t("cookie.banner.decline")}
      </button>
      <button
        id="consent-btn-accept"
        class="w-full py-2.5 px-4 rounded-xl font-medium text-white bg-btn-highlight hover:bg-btn-highlight/90 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer text-center text-[14px]"
      >
        {t("cookie.banner.accept")}
      </button>
    </div>

    <div class="flex items-center justify-between mt-1 px-1">
      <button
        id="consent-btn-customize"
        class="text-xs text-route hover:text-highlight transition-colors cursor-pointer"
        data-customize={t("cookie.banner.customize")}
        data-back={lang === "it" ? "Indietro" : "Back"}
      >
        {t("cookie.banner.customize")}
      </button>

      <button
        id="consent-btn-save"
        class="hidden text-xs font-semibold text-highlight hover:underline transition-all cursor-pointer"
      >
        {t("cookie.banner.save")}
      </button>
    </div>
  </div>
</div>

<script>
  import "../scripts/CookieHandler.ts";
</script>
