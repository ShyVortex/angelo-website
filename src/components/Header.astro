---
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
    getRouteFromUrl,
} from "../i18n/utils";
import avatarImg from "../assets/avatar.png";
import searchIconImg from "../assets/search.svg";
import themeIconImg from "../assets/mode-switch.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentRoute = getRouteFromUrl(Astro.url);
---

<header class="bg-bg-header text-main shadow-sm relative z-50" data-search-path={translatePath("/cerca")}>
    <div
        class="py-4 px-6 flex justify-between items-center md:grid md:grid-cols-3"
    >
        <a
            id="leftBanner"
            class="flex items-center select-none justify-self-start cursor-pointer"
            href={translatePath("/")}
        >
            <img
                width="50"
                height="50"
                class="block mr-4 rounded-full shrink-0 object-cover"
                draggable="false"
                src={avatarImg.src}
            />
            <div class="flex flex-col">
                <span
                    class="text-[15px] md:text-[20px] font-semibold leading-tight"
                    >Angelo Trotta</span
                >
                <span class="text-[8px] md:text-[12px] opacity-80"
                    >Web & Software Developer</span
                >
            </div>
        </a>
        <nav class="hidden md:flex gap-6 justify-self-center">
            <a
                href={translatePath("/")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.home")}
            </a>
            <a
                href={translatePath("/biografia")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "biografia" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.biografia")}
            </a>
            <a
                href={translatePath("/cv")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "cv" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.cv")}
            </a>
            <a
                href={translatePath("/skills")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "skills" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.skills")}
            </a>
            <a
                href={translatePath("/portfolio")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "portfolio" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.portfolio")}
            </a>
            <a
                href={translatePath("/contatti")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "contatti" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.contatti")}
            </a>
        </nav>
        <div class="flex items-center justify-self-end gap-1 md:gap-0">
            <!-- Expandable search bar -->
            <div
                id="search-container"
                class="flex items-center transition-all duration-300 w-0 opacity-0 overflow-hidden mr-2"
            >
                <input
                    type="text"
                    id="search-input"
                    placeholder={t("search.placeholder")}
                    class="bg-transparent border-b border-main focus:outline-none py-1 px-2 text-[16px] w-40 text-main"
                />
            </div>
 
            <button
                id="search-toggle-btn"
                class="focus:outline-none flex items-center justify-center w-[35px] h-[35px] mr-4 cursor-pointer"
                aria-label="Search"
            >
                <img
                    id="search-icon"
                    width="35"
                    height="35"
                    class="block rounded-full shrink-0 object-cover dark:invert"
                    draggable="false"
                    src={searchIconImg.src}
                    alt="Search"
                />
                <svg
                    id="close-icon"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    class="hidden text-main dark:text-white"
                >
                    <path
                        d="M18 6L6 18M6 6l12 12"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </svg>
            </button>

            <div class="hidden md:flex gap-1 items-center">
                <a
                    href={translatePath(currentRoute, "it")}
                    class={`text-[16px] hover:text-header-highlight transition-colors ${lang === "it" ? "text-header-highlight font-semibold" : "text-route"}`}
                >
                    ITA
                </a>
                <span class="text-[16px] opacity-50">|</span>
                <a
                    href={translatePath(currentRoute, "en")}
                    class={`text-[16px] hover:text-header-highlight transition-colors ${lang === "en" ? "text-header-highlight font-semibold" : "text-route"}`}
                >
                    ENG
                </a>
            </div>
            <button id="theme-switch-btn" class="focus:outline-none">
                <img
                    id="theme-icon"
                    width="35"
                    height="35"
                    class="block ml-1 md:ml-4 rounded-full shrink-0 object-cover cursor-pointer dark:invert"
                    draggable="false"
                    src={themeIconImg.src}
                />
            </button>
            <button
                id="mobile-menu-btn"
                class="block md:hidden focus:outline-none ml-6 cursor-pointer"
                aria-label="Menu"
            >
                <svg
                    id="menu-icon"
                    class="w-8 h-8 text-main dark:text-white"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    id="menu-close-icon"
                    class="hidden w-8 h-8 text-main dark:text-white"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Search Bar Dropdown -->
    <div
        id="mobile-search-container"
        class="hidden md:hidden border-t border-underline/10 py-3 px-6 bg-bg-header transition-all duration-300 items-center"
    >
        <input
            type="text"
            id="mobile-search-input"
            placeholder={t("search.placeholder")}
            class="bg-transparent border-b border-main focus:outline-none py-1 px-2 text-[16px] w-full text-main"
        />
    </div>

    <!-- Mobile Menu Dropdown -->
    <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-underline/10 py-6 px-6 flex-col gap-6 bg-bg-header transition-all duration-300"
    >
        <nav class="flex flex-col gap-4">
            <a
                href={translatePath("/")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.home")}</a
            >
            <a
                href={translatePath("/biografia")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "biografia" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.biografia")}</a
            >
            <a
                href={translatePath("/cv")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "cv" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.cv")}</a
            >
            <a
                href={translatePath("/skills")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "skills" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.skills")}</a
            >
            <a
                href={translatePath("/portfolio")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "portfolio" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.portfolio")}</a
            >
            <a
                href={translatePath("/contatti")}
                class={`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "contatti" ? "text-header-highlight underline underline-offset-8" : "text-route"}`}
                >{t("nav.contatti")}</a
            >
        </nav>
        <div class="flex gap-1 items-center pt-4 border-t border-underline/10">
            <a
                href={translatePath(currentRoute, "it")}
                class={`text-[16px] hover:text-header-highlight transition-colors ${lang === "it" ? "text-lang-selected font-semibold" : "text-route"}`}
            >
                ITA
            </a>
            <span class="text-[16px] opacity-50">|</span>
            <a
                href={translatePath(currentRoute, "en")}
                class={`text-[16px] hover:text-header-highlight transition-colors ${lang === "en" ? "text-lang-selected font-semibold" : "text-route"}`}
            >
                ENG
            </a>
        </div>
    </div>
</header>

<script>
    const searchToggleBtn = document.getElementById("search-toggle-btn");
    const searchContainer = document.getElementById("search-container");
    const searchInput = document.getElementById(
        "search-input",
    ) as HTMLInputElement | null;
    const searchIcon = document.getElementById("search-icon");
    const closeIcon = document.getElementById("close-icon");

    const themeSwitchBtn = document.getElementById("theme-switch-btn");

    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const menuCloseIcon = document.getElementById("menu-close-icon");

    const mobileSearchContainer = document.getElementById(
        "mobile-search-container",
    );
    const mobileSearchInput = document.getElementById(
        "mobile-search-input",
    ) as HTMLInputElement | null;

    const searchPath = document.querySelector("header")?.getAttribute("data-search-path") || "/cerca";

    const performSearch = (query: string) => {
        if (query.trim()) {
            window.location.href = `${searchPath}?q=${encodeURIComponent(query.trim())}`;
        }
    };

    searchInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            performSearch(searchInput.value);
        }
    });

    mobileSearchInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            performSearch(mobileSearchInput.value);
        }
    });

    const urlParams = new URLSearchParams(window.location.search);
    const queryParam = urlParams.get("q");
    if (queryParam) {
        if (searchInput) searchInput.value = queryParam;
        if (mobileSearchInput) mobileSearchInput.value = queryParam;
    }

    if (
        searchToggleBtn &&
        searchContainer &&
        searchIcon &&
        closeIcon &&
        mobileSearchContainer
    ) {
        searchToggleBtn.addEventListener("click", () => {
            // If screen width is below md (768px), we use the mobile search bar below header
            const isMobile = window.innerWidth < 768;
 
            if (isMobile) {
                const isClosed =
                    mobileSearchContainer.classList.contains("hidden");
                if (isClosed) {
                    // Close mobile menu if it is open
                    if (
                        mobileMenu &&
                        !mobileMenu.classList.contains("hidden")
                    ) {
                        mobileMenu.classList.add("hidden");
                        mobileMenu.classList.remove("flex");
                        menuIcon?.classList.remove("hidden");
                        menuCloseIcon?.classList.add("hidden");
                    }
                    // Show mobile search bar
                    mobileSearchContainer.classList.remove("hidden");
                    mobileSearchContainer.classList.add("flex");
                    searchIcon.classList.add("hidden");
                    closeIcon.classList.remove("hidden");
                    setTimeout(() => mobileSearchInput?.focus(), 150);
                } else {
                    // Hide mobile search bar
                    mobileSearchContainer.classList.add("hidden");
                    mobileSearchContainer.classList.remove("flex");
                    searchIcon.classList.remove("hidden");
                    closeIcon.classList.add("hidden");
                    if (mobileSearchInput) mobileSearchInput.value = "";
                }
            } else {
                const isClosed = searchContainer.classList.contains("w-0");
                if (isClosed) {
                    searchContainer.classList.remove("w-0", "opacity-0");
                    searchContainer.classList.add("w-40", "opacity-100");
                    searchIcon.classList.add("hidden");
                    closeIcon.classList.remove("hidden");
                    setTimeout(() => searchInput?.focus(), 150);
                } else {
                    searchContainer.classList.remove("w-40", "opacity-100");
                    searchContainer.classList.add("w-0", "opacity-0");
                    searchIcon.classList.remove("hidden");
                    closeIcon.classList.add("hidden");
                    if (searchInput) searchInput.value = "";
                }
            }
        });
    }
 
    if (themeSwitchBtn) {
        themeSwitchBtn.addEventListener("click", () => {
            const isDark = document.documentElement.classList.contains("dark");
            if (isDark) {
                document.documentElement.classList.remove("dark");
                localStorage.setItem("theme", "light");
            } else {
                document.documentElement.classList.add("dark");
                localStorage.setItem("theme", "dark");
            }
        });
    }
 
    if (mobileMenuBtn && mobileMenu && menuIcon && menuCloseIcon) {
        mobileMenuBtn.addEventListener("click", () => {
            const isHidden = mobileMenu.classList.contains("hidden");
            if (isHidden) {
                // Close mobile search if it is open
                if (
                    mobileSearchContainer &&
                    !mobileSearchContainer.classList.contains("hidden")
                ) {
                    mobileSearchContainer.classList.add("hidden");
                    mobileSearchContainer.classList.remove("flex");
                    searchIcon?.classList.remove("hidden");
                    closeIcon?.classList.add("hidden");
                }
 
                mobileMenu.classList.remove("hidden");
                mobileMenu.classList.add("flex");
                menuIcon.classList.add("hidden");
                menuCloseIcon.classList.remove("hidden");
            } else {
                mobileMenu.classList.add("hidden");
                mobileMenu.classList.remove("flex");
                menuIcon.classList.remove("hidden");
                menuCloseIcon.classList.add("hidden");
            }
        });
    }
</script>
