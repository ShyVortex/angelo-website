---
import Card from "./Card.astro";
import type { CardRaw, LocalString } from "../types/CardRaw";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
    cards: CardRaw[];
    translationPrefix?: string;
    layout?: "left" | "centered";
}

const { cards, translationPrefix = "card", layout = "left" } = Astro.props;

// Copy array to avoid mutating the original array passed as a prop
const sortedCards = [...cards];

// If cards have date property, sort in descending order
if (sortedCards.some((card) => card.date)) {
    sortedCards.sort((a, b) => {
        // Convert DD/MM/YYYY to YYYY-MM-DD
        const [dayA, monthA, yearA] = a.date!.split("/");
        const [dayB, monthB, yearB] = b.date!.split("/");

        const dateA = `${yearA}-${monthA}-${dayA}`;
        const dateB = `${yearB}-${monthB}-${dayB}`;

        // Descending order: b - a
        return dateB.localeCompare(dateA);
    });
}
---

<div
    id="cards-grid"
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl w-full mb-16 reveal-on-scroll opacity-0 translate-y-8 transition-all duration-700 ease-out"
>
    {
        sortedCards.map((card: CardRaw) => {
            let name: string = "";

            if (typeof card.name === "string") {
                name =
                    t(`${translationPrefix}.${card.id}.name` as any) ||
                    (card.name as string);
            } else if (typeof card.name === "object") {
                if (lang === "it") {
                    name =
                        t(`${translationPrefix}.${card.id}.name.it` as any) ||
                        (card.name.it as string);
                } else if (lang === "en") {
                    name =
                        t(`${translationPrefix}.${card.id}.name.en` as any) ||
                        (card.name.en as string);
                }
            }

            const desc = t(`${translationPrefix}.${card.id}.desc` as any);
            const searchTerms =
                `${name} ${desc} ${card.tags.join(" ")}`.toLowerCase();

            return (
                <div
                    class="card"
                    data-category={card.category}
                    data-search={searchTerms}
                >
                    <Card
                        layout={layout}
                        iconName={card.icon}
                        title={name}
                        description={desc}
                        link={card.link ? card.link : undefined}
                        tags={card.tags}
                        rating={card.rating ? card.rating : undefined}
                        ratingLabel={
                            card.rating ? t("skills.level") : undefined
                        }
                        date={card.date ? card.date : undefined}
                    />
                </div>
            );
        })
    }
</div>
