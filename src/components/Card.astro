---
import { Icon } from "astro-icon/components";

interface Props {
    customImg?: HTMLElement;
    iconName?: string;
    title: string;
    description: string;
    tags?: string | string[];
}

const { customImg, iconName, title, description, tags } = Astro.props;

const tagList = tags
    ? (typeof tags === "string"
        ? tags.split(",").map((t) => t.trim())
        : tags)
    : [];
---

<div
    class="mb-5 h-full w-full justify-center items-center text-center rounded-2xl border border-underline/10 shadow-xl bg-bg-card p-6 md:p-8 transition-all duration-300 hover:-translate-y-1 hover:border-highlight/30 hover:shadow-2xl"
>
    {customImg ? (customImg) : (<></>)}
    {iconName ? (
        <Icon class="mx-auto" width="50px" height="50px" name={iconName} />
    )
        : (<></>)
    }
    <p class="mt-3 text-main font-bold">{title}</p>
    <p class="mt-5 text-main">{description}</p>
    
    {tagList.length > 0 && (
        <div class="flex flex-wrap gap-2 justify-center mt-6">
            {tagList.map((tag) => (
                <span class="px-3 py-1 text-sm font-mono rounded-lg bg-bg-tag border border-underline/20 text-main">
                    {tag}
                </span>
            ))}
        </div>
    )}
</div>

