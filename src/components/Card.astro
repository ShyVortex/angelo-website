---
import { Icon } from "astro-icon/components";

interface Props {
    customImg?: HTMLElement;
    iconName?: string;
    title: string;
    description: string;
    tags?: string | string[];
    rating?: number;
    layout?: "centered" | "left";
    ratingLabel?: string;
    link?: string;
    date?: string;
}

const {
    customImg,
    iconName,
    title,
    description,
    tags,
    rating,
    layout = "centered",
    ratingLabel,
    link,
    date
} = Astro.props;

const tagList = tags
    ? typeof tags === "string"
        ? tags.split(",").map((t) => t.trim())
        : tags
    : [];

// Star calculation for left layout
const fullStars = rating ? Math.floor(rating) : 0;
const hasHalf = rating ? rating % 1 !== 0 : false;
const emptyStars = rating ? 5 - fullStars - (hasHalf ? 1 : 0) : 0;

// Dynamic tag depending on whether it is a link or not
const Tag = link ? "a" : "div";
---

{
    layout === "centered" ? (
        <Tag
            class="mb-5 block h-full w-full text-center rounded-2xl border border-underline/10 shadow-xl bg-bg-card p-6 md:p-8 transition-all duration-300 hover:-translate-y-1 hover:border-highlight/30 hover:shadow-2xl"
            href={link ? link : undefined}
        >
            {customImg ? customImg : <></>}
            {iconName ? (
                <Icon
                    class="mx-auto text-highlight"
                    width="50px"
                    height="50px"
                    name={iconName}
                />
            ) : (
                <></>
            )}
            <p class="mt-3 text-main font-bold">{title}</p>
            <p class="mt-5 text-main">{description}</p>

            {tagList.length > 0 && (
                <div class="flex flex-wrap gap-2 justify-center mt-6">
                    {tagList.map((tag) => (
                        <span class="px-3 py-1 text-sm font-mono rounded-lg bg-bg-tag border border-underline/20 text-main">
                            {tag}
                        </span>
                    ))}
                </div>
            )}
        </Tag>
    ) : (
        <Tag
            class="h-full w-full flex flex-col justify-between rounded-2xl border border-underline/10 bg-bg-card p-6 md:p-7 transition-all duration-300 hover:border-highlight/30 hover:shadow-2xl hover:-translate-y-1 relative group overflow-hidden"
            href={link ? link : undefined}
        >
            {/* Decorative Background Accent */}
            <div class="absolute -right-8 -bottom-8 w-24 h-24 bg-gradient-to-br from-highlight/5 to-lang-selected/5 rounded-full blur-xl group-hover:scale-150 transition-all duration-500 pointer-events-none" />

            <div>
                {/* Card Header (Icon & Name) */}
                <div class="flex items-center gap-4 mb-4">
                    {iconName && (
                        <div class="p-3 bg-gradient-to-tr from-highlight/10 to-lang-selected/5 border border-underline/10 rounded-xl group-hover:from-highlight/15 group-hover:border-highlight/20 transition-all duration-300 shadow-sm">
                            <Icon
                                name={iconName}
                                width="38px"
                                height="38px"
                                class="text-highlight group-hover:scale-110 transition-transform duration-300"
                            />
                        </div>
                    )}
                    <div>
                        <h3 class="text-lg font-bold text-main">{title}</h3>
                        {/* Star Rating indicator */}
                        {rating !== undefined && (
                            <div
                                class="flex items-center gap-0.5 mt-1"
                                aria-label={`${ratingLabel}: ${rating}/5`}
                            >
                                {Array.from({ length: fullStars }).map(() => (
                                    <Icon
                                        name="mdi:star"
                                        width="16px"
                                        height="16px"
                                        class="text-amber-500 dark:text-amber-400"
                                    />
                                ))}
                                {hasHalf && (
                                    <Icon
                                        name="mdi:star-half-full"
                                        width="16px"
                                        height="16px"
                                        class="text-amber-500 dark:text-amber-400"
                                    />
                                )}
                                {Array.from({ length: emptyStars }).map(() => (
                                    <Icon
                                        name="mdi:star-outline"
                                        width="16px"
                                        height="16px"
                                        class="text-route/30"
                                    />
                                ))}
                            </div>
                        )}
                        {/* Date indicator */}
                        {date !== undefined && (
                            <div
                                class="flex items-center gap-0.5 mt-1"
                            >
                                <p class="text-[13px] text-route">{date}</p>
                            </div>
                        )}
                    </div>
                </div>

                {/* Description */}
                <p class="text-route text-[14px] leading-relaxed mb-5">
                    {description}
                </p>
            </div>

            {/* Tech tags */}
            {tagList.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-auto pt-4 border-t border-underline/5">
                    {tagList.map((tag) => (
                        <span class="px-2.5 py-0.5 text-[11px] font-semibold tracking-wide rounded-md bg-bg-tag border border-underline/10 text-main transition-colors group-hover:bg-bg-tag/80">
                            {tag}
                        </span>
                    ))}
                </div>
            )}
        </Tag>
    )
}
