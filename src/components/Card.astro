---
import { Icon } from "astro-icon/components";

interface Props {
    customImg?: HTMLElement;
    iconName?: string;
    title: string;
    description: string;
}

const { customImg, iconName, title, description } = Astro.props;
---

<div
    class="mb-5 h-full w-full justify-center items-center text-center rounded-2xl border border-underline/10 shadow-xl bg-bg-card p-6 md:p-8 transition-colors transition-shadow duration-300 hover:shadow-2xl"
>
    {customImg ? (customImg) : (<></>)}
    {iconName ? (
        <Icon class="mx-auto" width="50px" height="50px" name={iconName} />
    )
        : (<></>)
    }
    <p class="mt-3 text-main font-bold">{title}</p>
    <p class="mt-5 text-main">{description}</p>
</div>
