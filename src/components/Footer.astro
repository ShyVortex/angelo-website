---
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "../i18n/utils";
import { getRouteFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentRoute = getRouteFromUrl(Astro.url);
---

<footer
    class="bg-bg-footer text-main py-8 px-6 md:px-20 shadow-sm grid grid-cols-1 md:grid-cols-2 gap-8 items-center"
>
    <div class="flex flex-col select-none justify-self-start md:ml-5">
        <span class="text-[20px] font-semibold leading-tight"
            >Angelo Trotta</span
        >
        <span class="text-[12px] opacity-80">Web & Software Developer</span>
        <span class="mt-6 text-[14px] text-route">
            {t("footer.rights")}<br />
            {t("footer.source")}
            <a
                href="https://github.com/ShyVortex/angelo-website"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline">GitHub</a
            >
            {t("footer.source_suffix1")}<br />
            {t("footer.source_suffix2")}
        </span>
    </div>
    <div class="flex flex-col select-none justify-self-start md:items-end">
        <nav class="flex flex-wrap gap-4 md:gap-6 justify-start md:justify-end">
            <a
                href={translatePath("/")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "" ? "text-header-highlight" : "text-route"}`
                >{t("nav.home")}</a
            >
            <a
                href={translatePath("/biografia")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "biografia" ? "text-header-highlight" : "text-route"}`
                >{t("nav.biografia")}</a
            >
            <a
                href={translatePath("/cv")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "cv" ? "text-header-highlight" : "text-route"}`
                >{t("nav.cv")}</a
            >
            <a
                href={translatePath("/skills")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "skills" ? "text-header-highlight" : "text-route"}`
                >{t("nav.skills")}</a
            >
            <a
                href={translatePath("/portfolio")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "portfolio" ? "text-header-highlight" : "text-route"}`
                >{t("nav.portfolio")}</a
            >
            <a
                href={translatePath("/contatti")}
                class=`text-[20px] hover:text-header-highlight transition-colors ${currentRoute === "contatti" ? "text-header-highlight" : "text-route"}`
                >{t("nav.contatti")}</a
            >
            <a
                href={"https://github.com/ShyVortex"}
                target="_blank"
                rel="noopener noreferrer"
                class=`text-[20px] text-route hover:text-header-highlight transition-colors`
                >GitHub</a
            >
        </nav>
        <span class="mt-6 text-[14px] text-route md:text-right">
            {t("footer.accessibility_prefix")}
            <a
                href="https://eur-lex.europa.eu/legal-content/IT/TXT/?uri=CELEX:32019L0882"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline"
                >{t("footer.accessibility_link")}
            </a>
        </span>
        <span
            class="mt-2 text-[14px] text-route md:text-right flex flex-wrap gap-y-1 gap-x-3 justify-start md:justify-end"
        >
            <a
                href="https://www.iubenda.com/privacy-policy/42688437"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline"
                >{t("footer.privacy")}</a
            >
            <span class="text-route/30 select-none hidden sm:inline">|</span>
            <a
                href="https://www.iubenda.com/privacy-policy/42688437/cookie-policy"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline"
                >{t("footer.cookie_policy")}</a
            >
            <span class="text-route/30 select-none hidden sm:inline">|</span>
            <a
                href="#"
                onclick="if (window.openCookieBanner) { window.openCookieBanner(); } return false;"
                class="text-footer-highlight hover:underline"
                >{t("footer.cookie_preferences")}</a
            >
        </span>
    </div>
</footer>
