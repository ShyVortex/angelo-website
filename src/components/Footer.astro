---
import {
    getLangFromUrl,
    useTranslations,
    useTranslatedPath,
} from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer
    class="bg-bg-footer text-main py-4 px-6 shadow-sm grid grid-cols-2 items-center"
>
    <div class="pl-20 pt-5 pb-5 flex flex-col select-none justify-self-start">
        <span class="text-[20px] font-semibold leading-tight"
            >Angelo Trotta</span
        >
        <span class="text-[12px] opacity-80">Web & Software Developer</span>
        <span class="mt-10 text-[14px] text-route">
            {t("footer.rights")}<br />
            {t("footer.source")}
            <a
                href="https://github.com/ShyVortex/angelo-website"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline">GitHub</a
            >
            {t("footer.source_suffix1")}<br />
            {t("footer.source_suffix2")}
        </span>
    </div>
    <div class="pl-20 pt-5 pb-5 flex flex-col select-none justify-self-start">
        <nav class="flex gap-6 justify-self-center">
            <a
                href={translatePath("/")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.home")}</a
            >
            <a
                href={translatePath("/biografia")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.biografia")}</a
            >
            <a
                href={translatePath("/cv")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.cv")}</a
            >
            <a
                href={translatePath("/skills")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.skills")}</a
            >
            <a
                href={translatePath("/portfolio")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.portfolio")}</a
            >
            <a
                href={translatePath("/contatti")}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >{t("nav.contatti")}</a
            >
            <a
                href={"https://github.com/ShyVortex"}
                class="text-[20px] text-route hover:text-header-highlight transition-colors"
                >GitHub</a
            >
        </nav>
        <span class="mt-10 text-[14px] text-route">
            {t("footer.accessibility_prefix")}
            <a
                href="https://eur-lex.europa.eu/legal-content/IT/TXT/?uri=CELEX:32019L0882"
                target="_blank"
                rel="noopener noreferrer"
                class="text-footer-highlight hover:underline"
                >{t("footer.accessibility_link")}
            </a>
        </span>
        <span class="mt-2 text-[14px] text-route">
            <a href="#" class="text-footer-highlight hover:underline"
                >{t("footer.privacy")}</a
            >
        </span>
    </div>
</footer>
