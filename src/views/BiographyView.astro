---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import avatar2Img from "../assets/avatar2.png";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
    id="biografia"
    class="mt-10 flex flex-col items-center justify-center px-4"
>
    <div
        class="text-center max-w-5xl w-full reveal-on-scroll opacity-0 translate-y-6 transition-all duration-1000 ease-out"
    >
        <h1
            class="text-4xl md:text-4xl font-bold text-highlight mb-4 drop-shadow-sm"
        >
            {t("nav.biografia")}
        </h1>
    </div>

    <div
        class="flex flex-col items-center reveal-on-scroll opacity-0 translate-y-8 transition-all duration-750 ease-out"
    >
        <img
            src={avatar2Img.src}
            alt="Angelo Trotta"
            class="mt-8 w-32 h-32 md:w-40 md:h-40 rounded-full object-cover border-2 border-highlight shadow-md shrink-0"
            draggable="false"
        />
        <p
            class="mt-8 text-center max-w-4xl w-full"
            set:html={t("bio.summary")}
        />
    </div>

    <div
        class="flex flex-col mt-8 self-left max-w-4xl w-full text-left justify-start items-start reveal-on-scroll opacity-0 translate-y-8 transition-all duration-700 ease-out"
    >
        <h1 class="text-left text-2xl font-bold flex items-center gap-2">
            <Icon name="ph:graduation-cap-fill" class="w-7 h-7 text-main" />
            {t("bio.edu_title")}
        </h1>
        <p class="mt-4" set:html={t("bio.edu_desc")} />
    </div>
    <div
        class="flex flex-col mt-8 self-left max-w-4xl w-full text-left justify-start items-start reveal-on-scroll opacity-0 translate-y-8 transition-all duration-700 ease-out"
    >
        <h1 class="text-left text-2xl font-bold flex items-center gap-2">
            <Icon name="mdi:toolbox" class="w-7 h-7 text-main" />
            {t("bio.work_title")}
        </h1>
        <p class="mt-4" set:html={t("bio.work_desc")} />
    </div>
    <div
        class="flex flex-col mt-8 self-left max-w-4xl w-full text-left justify-start items-start reveal-on-scroll opacity-0 translate-y-8 transition-all duration-700 ease-out"
    >
        <h1 class="text-left text-2xl font-bold flex items-center gap-2">
            <Icon name="mdi:clock" class="w-7 h-7 text-main" />
            {t("bio.hobbies_title")}
        </h1>
        <p class="mt-4" set:html={t("bio.hobbies_desc")} />
    </div>
    <div
        class="flex flex-col mt-8 mb-20 self-left max-w-4xl w-full text-left justify-start items-start reveal-on-scroll opacity-0 translate-y-8 transition-all duration-700 ease-out"
    >
        <h1 class="text-left text-2xl font-bold flex items-center gap-2">
            <Icon name="mdi:star-three-points" class="w-7 h-7 text-main" />
            {t("bio.info_title")}
        </h1>
        <p class="mt-4" set:html={t("bio.info_desc")} />
    </div>
</div>

<script is:inline type="module" src="src/scripts/RenderOnScroll.ts"></script>
